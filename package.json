{
  "name": "ha-solar-view-card",
  "version": "1.0.0",
  "description": "Home Assistant custom Lovelace card displaying a planetary solar system visualization",
  "type": "module",
  "scripts": {
    "build": "rollup -c && cp dist/ha-solar-view-card.js docs/",
    "build:prod": "NODE_ENV=production rollup -c",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "biome format --write src/ test/",
    "format:check": "biome format src/ test/",
    "lint": "biome lint src/ test/",
    "lint:fix": "biome lint --write src/ test/",
    "check": "biome check src/ test/",
    "check:fix": "biome check --write src/ test/",
    "format:md": "prettier --write \"**/*.md\"",
    "format:md:check": "prettier --check \"**/*.md\""
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "solar-system"
  ],
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "rollup": "^4.57.1",
    "vitest": "^4.0.18"
  }
}
