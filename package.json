{
  "name": "ha-planetary-solar-system-card",
  "version": "0.0.0-dev",
  "description": "Home Assistant custom Lovelace card displaying a planetary solar system visualization",
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "build": "rollup -c",
    "build:prod": "NODE_ENV=production rollup -c",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "biome format --write src/ test/",
    "format:check": "biome format src/ test/",
    "lint": "biome lint src/ test/",
    "lint:fix": "biome lint --write src/ test/",
    "check": "biome check --write src/ test/",
    "check:fix": "biome check --write src/ test/",
    "typecheck": "tsc --noEmit",
    "check:ci": "tsc --noEmit && biome check src/ test/ && prettier --check \"**/*.md\"",
    "format:md": "prettier --write \"**/*.md\"",
    "format:md:check": "prettier --check \"**/*.md\""
  },
  "keywords": [
    "home-assistant",
    "lovelace",
    "solar-system"
  ],
  "prettier": "ha-card-shared/prettier.config.json",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@vitest/coverage-v8": "^4.1.8",
    "ha-card-shared": "github:marcintk/ha-card-shared#v1.1.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "rollup": "^4.57.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "lit": "^3.3.3"
  }
}
